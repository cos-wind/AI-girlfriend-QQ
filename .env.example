BOT_QQ=3380609082
HOST=127.0.0.1
PORT=8765

# private: only reply to private messages
# mention: private messages + group messages that mention the bot or "亚托莉"
# smart: private messages + owner/group direct triggers; avoids replying to every group message
# all: reply to all messages (not recommended)
REPLY_MODE=smart

# Default: local Ollama OpenAI-compatible chat API.
# Leave OPENAI_API_KEY empty to use local fallback replies only.
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_MODEL=qwen3:4b-instruct

# Controls the reply style when an API key is configured.
TEMPERATURE=0.60
FREQUENCY_PENALTY=0.35
MAX_TOKENS=180

# Send replies as several short QQ messages, like streaming.
MESSAGE_SPLIT_MAX_CHARS=44
MESSAGE_SPLIT_MAX_PARTS=4
MESSAGE_SEND_DELAY_MIN=0.55
MESSAGE_SEND_DELAY_MAX=1.35

# Local stickers. Put images under data/stickers/<emotion>/.
STICKER_DIR=data/stickers
STICKER_TRIGGER_FILE=data/stickers/triggers.json
STICKER_CHANCE=0.32
STICKER_COOLDOWN_SECONDS=120
STICKER_CAPTURE_ENABLED=true
STICKER_CAPTURE_MAX_BYTES=3000000

# User habit memory and light idle care.
MEMORY_PATH=data/memory/users.json
OWNER_QQ=
IDLE_PROACTIVE_ENABLED=true
IDLE_MINUTES=120
IDLE_COOLDOWN_MINUTES=480
IDLE_CHECK_SECONDS=60

# Group chat context and low-frequency cold-room nudges.
# Hard cap is 3 proactive messages per group per day.
GROUP_CONTEXT_ENABLED=true
GROUP_PROACTIVE_ENABLED=true
GROUP_PROACTIVE_IDLE_MINUTES=60
GROUP_PROACTIVE_COOLDOWN_MINUTES=180
GROUP_PROACTIVE_DAILY_LIMIT=3
GROUP_PROACTIVE_CHECK_SECONDS=90

# Daily morning greeting. If OWNER_QQ is empty, it sends to private users who have chatted with her.
MORNING_GREETING_ENABLED=true
MORNING_GREETING_TIME=07:30
MORNING_GREETING_TIMEZONE=Asia/Shanghai
MORNING_GREETING_CATCHUP_MINUTES=90

# Material toolbox: documents, tables, webpages, images, and direct video files.
TOOLBOX_ENABLED=true
TOOLBOX_TIMEOUT_SECONDS=18
TOOLBOX_MAX_BYTES=2000000
TOOLBOX_MAX_DOCUMENT_BYTES=20000000
TOOLBOX_MAX_MEDIA_BYTES=80000000
TOOLBOX_VISION_ENABLED=true
TOOLBOX_VISION_MODEL=qwen2.5vl:3b
TOOLBOX_VISION_BASE_URL=http://127.0.0.1:11434/v1
TOOLBOX_VISION_API_KEY=ollama
TOOLBOX_VISION_MAX_BYTES=8000000
TOOLBOX_VIDEO_FRAME_ANALYSIS_ENABLED=true
TOOLBOX_VIDEO_MAX_FRAMES=4

# LLM tool calling: the model may call local time or web search when context needs it.
LLM_TOOLS_ENABLED=true
LLM_TOOL_MAX_CALLS=2
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT_SECONDS=6
WEB_SEARCH_MAX_RESULTS=5
