[Unit]
Description=Atri QQ Companion Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/atri-qq-bot
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONUTF8=1
ExecStart=/opt/atri-qq-bot/.venv/bin/python -m atri_qq_bot
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
