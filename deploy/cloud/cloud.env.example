BOT_QQ=3380609082
HOST=127.0.0.1
PORT=8765
REPLY_MODE=mention

# Fill your own QQ here if you want morning greetings to always go to you.
# If empty, Atri sends morning greetings to private users who have chatted with her.
OWNER_QQ=

# When the PC is off, the model must also be reachable from the cloud server.
# Option A: install Ollama on the cloud server and keep this local address.
# Option B: use an OpenAI-compatible model provider URL and API key.
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_MODEL=qwen2.5:7b
TEMPERATURE=0.7
MAX_TOKENS=280

MESSAGE_SPLIT_MAX_CHARS=44
MESSAGE_SPLIT_MAX_PARTS=4
MESSAGE_SEND_DELAY_MIN=0.55
MESSAGE_SEND_DELAY_MAX=1.35

STICKER_DIR=data/stickers
STICKER_TRIGGER_FILE=data/stickers/triggers.json
STICKER_CHANCE=0.32
STICKER_COOLDOWN_SECONDS=120
STICKER_CAPTURE_ENABLED=true
STICKER_CAPTURE_MAX_BYTES=3000000

MEMORY_PATH=data/memory/users.json
IDLE_PROACTIVE_ENABLED=true
IDLE_MINUTES=180
IDLE_COOLDOWN_MINUTES=720
IDLE_CHECK_SECONDS=60

MORNING_GREETING_ENABLED=true
MORNING_GREETING_TIME=07:30
MORNING_GREETING_TIMEZONE=Asia/Shanghai
MORNING_GREETING_CATCHUP_MINUTES=90
